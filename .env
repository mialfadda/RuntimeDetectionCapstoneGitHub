# ============================================================
# FLASK ENVIRONMENT
# ============================================================
FLASK_APP=run.py
FLASK_ENV=development

# ============================================================
# SECRET KEYS
# ============================================================
SECRET_KEY=your-super-secret-key-change-this-in-production-use-random-string
JWT_SECRET_KEY=your-jwt-secret-key-also-change-this

# ============================================================
# DATABASE
# ============================================================
# Development (SQLite)
DATABASE_URL=sqlite:///capstone.db

# Production (PostgreSQL) - uncomment when deploying
# DATABASE_URL=postgresql://username:password@localhost:5432/phishing_detection

# ============================================================
# REDIS (For Celery and Rate Limiting)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# CLOUD CREDENTIALS (Optional - only if using cloud services)
# ============================================================

# AWS (if deploying to AWS)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# Azure (if deploying to Azure)
# AZURE_STORAGE_CONNECTION_STRING=your-connection-string

# Google Cloud (if deploying to GCP)
# GCP_PROJECT_ID=your-project-id
# GCP_CREDENTIALS_PATH=/path/to/credentials.json

# ============================================================
# API KEYS (if you need external services)
# ============================================================
